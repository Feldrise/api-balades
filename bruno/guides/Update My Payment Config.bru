meta {
  name: Update My Payment Config (guide)
  type: http
  seq: 5
}

put {
  url: {{base_url}}/guides/me/payment-config
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

body:json {
  {
    "payment_enabled": true
  }
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
